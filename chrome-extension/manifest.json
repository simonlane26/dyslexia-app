{
  "manifest_version": 3,
  "name": "Dyslexia Write",
  "version": "1.0.0",
  "description": "Confidence support for dyslexic writers — write anywhere with the right tools.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dyslexia Write",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
